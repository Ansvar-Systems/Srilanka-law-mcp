{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "Sri Lanka Law MCP",
  "description": "Golden contract tests for the Sri Lanka Law MCP -- tests against real legislation from commonlii.org/lk",
  "tests": [
    {
      "id": "T001",
      "category": "search",
      "description": "Search for provisions mentioning 'court'",
      "tool": "search_legislation",
      "input": { "query": "court", "limit": 5 },
      "assertions": {
        "result_not_empty": true,
        "min_results": 3
      }
    },
    {
      "id": "T002",
      "category": "search",
      "description": "Search for provisions mentioning 'paddy land'",
      "tool": "search_legislation",
      "input": { "query": "paddy land", "limit": 5 },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["paddy"]
      }
    },
    {
      "id": "T003",
      "category": "get_provision",
      "description": "Get section 1 of the Admiralty Jurisdiction Act",
      "tool": "get_provision",
      "input": { "document_id": "lk-act-aja40o1983300", "article": "1" },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["admiralty"],
        "text_not_empty": true
      }
    },
    {
      "id": "T004",
      "category": "get_provision",
      "description": "Get all provisions from a small act",
      "tool": "get_provision",
      "input": { "document_id": "lk-act-aoca1o1964317" },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1
      }
    },
    {
      "id": "T005",
      "category": "list_sources",
      "description": "List data sources",
      "tool": "list_sources",
      "input": {},
      "assertions": {
        "result_not_empty": true,
        "text_not_empty": true
      }
    },
    {
      "id": "T006",
      "category": "about",
      "description": "Server about information",
      "tool": "about",
      "input": {},
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "T007",
      "category": "search",
      "description": "Search with no results returns empty gracefully",
      "tool": "search_legislation",
      "input": { "query": "xyzzy_nonexistent_term_12345", "limit": 5 },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "T008",
      "category": "validate_citation",
      "description": "Validate citation for the Admiralty Jurisdiction Act section 1",
      "tool": "validate_citation",
      "input": { "citation": "Section 1, Admiralty Jurisdiction Act" },
      "assertions": {
        "result_not_empty": true,
        "text_not_empty": true
      }
    },
    {
      "id": "T009",
      "category": "check_currency",
      "description": "Check currency of the Agrarian Development Act",
      "tool": "check_currency",
      "input": { "document_id": "lk-act-ada46o2000248" },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["in_force"]
      }
    },
    {
      "id": "T010",
      "category": "search",
      "description": "Full-text search for 'agriculture'",
      "tool": "search_legislation",
      "input": { "query": "agriculture", "limit": 10 },
      "assertions": {
        "result_not_empty": true,
        "min_results": 3,
        "any_result_contains": ["agri"]
      }
    },
    {
      "id": "T011",
      "category": "get_provision",
      "description": "Get interpretation section from Agrarian Development Act",
      "tool": "get_provision",
      "input": { "document_id": "lk-act-ada46o2000248", "article": "101" },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["means"],
        "text_not_empty": true
      }
    },
    {
      "id": "T012",
      "category": "build_legal_stance",
      "description": "Build legal stance on property rights",
      "tool": "build_legal_stance",
      "input": { "query": "property rights tenant", "limit": 5 },
      "assertions": {
        "result_not_empty": true,
        "text_not_empty": true
      }
    },
    {
      "id": "T013",
      "category": "format_citation",
      "description": "Format a citation",
      "tool": "format_citation",
      "input": { "citation": "Section 1, Admiralty Jurisdiction Act", "format": "full" },
      "assertions": {
        "result_not_empty": true,
        "text_not_empty": true
      }
    },
    {
      "id": "T014",
      "category": "get_provision",
      "description": "Get non-existent provision handles gracefully",
      "tool": "get_provision",
      "input": { "document_id": "lk-act-nonexistent", "article": "999" },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
